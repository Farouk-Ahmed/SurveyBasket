{
  "version": "2",
  "type": "backend",
  "product": "SurveyBasket API",
  "requirements": [
    {
      "id": "Auth",
      "name": "Authentication",
      "description": "User registration, login, JWT and refresh token",
      "endpoints": [
        { "method": "POST", "path": "/api/Auth/register", "description": "Register with email and password" },
        { "method": "POST", "path": "/api/Auth/login", "description": "Login with email and password" },
        { "method": "POST", "path": "/api/Auth/refresh", "description": "Refresh JWT using refresh token" }
      ]
    },
    {
      "id": "Clients",
      "name": "Clients API",
      "description": "Client profile and avatar",
      "endpoints": [
        { "method": "GET", "path": "/api/Clients/me", "description": "Get current client profile" },
        { "method": "PUT", "path": "/api/Clients/me", "description": "Update client profile" },
        { "method": "PUT", "path": "/api/Clients/me/avatar", "description": "Update client avatar" }
      ]
    },
    {
      "id": "Dashboard",
      "name": "Dashboard API",
      "description": "Admin dashboard",
      "endpoints": [
        { "method": "GET", "path": "/api/Dashboard/summary", "description": "Dashboard summary" },
        { "method": "GET", "path": "/api/Dashboard/audit-logs", "description": "Audit logs" },
        { "method": "POST", "path": "/api/Dashboard/create-user", "description": "Create user (admin)" }
      ]
    },
    {
      "id": "Polls",
      "name": "Polls API",
      "description": "Polls list and management",
      "endpoints": [
        { "method": "GET", "path": "/api/Polls", "description": "Get polls list" }
      ]
    }
  ]
}
